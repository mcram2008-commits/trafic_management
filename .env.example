# WhatsApp Business Cloud API Settings
# Replace these values with your actual Meta developer credentials

# 1. Meta Permanent System Access Token (Bearer Token)
META_ACCESS_TOKEN=your_meta_permanent_access_token_here

# 2. WhatsApp Business Phone Number ID (From WhatsApp Settings in Meta dashboard)
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# 3. Webhook Verify Token (Create your own secret string, then copy it into Meta Dashboard Webhook Configuration)
META_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# 4. Express Server Settings
PORT=3000
